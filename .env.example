# Copy to .env and fill in from Supabase: Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
#
# First-time setup: create tables + RLS — run supabase/schema.sql in Supabase → SQL Editor,
# or from your Mac: install psql, set DATABASE_URL (Project Settings → Database → URI), then
#   ./scripts/run-supabase-sql.sh
# (Do not put DATABASE_URL in .env if this repo is public — use a local shell export only.)
